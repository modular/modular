# Target: token sampler `fused_token_sampling_gpu` (the production top-k+top-p
# sampling op). Two oracles: (1) a validity contract that every sampled
# out_idxs is in [0, vocab) -- a negative / out-of-range token id is FAIL; and
# (2) memory-safety on a FRESH int64 output buffer, so an UNWRITTEN row surfaces
# under initcheck/memcheck or poison (0xFF -> large negative token id).
# Covers three distinct bugs (all hardware-independent control-flow gaps):
#  - gumbel path (top_k=-1, the served greedy config): an all-NaN logits row
#    makes the argmax (TopK_2 seeded p=-1, u=-Inf) match no element > -Inf, so
#    it emits index -1 (logit_sign=3). This is the production negative-token id.
#  - gumbel temperature=0 unclamped divide (apply_gumbel_noise_kernel) on an
#    all-<=0 row -> all -Inf -> index -1 (logit_sign=1, temp=0).
#  - _topk_stage2 per-row top_k == 0 (k_lo=0) -> output row never written (the
#    Python per-row top_k tensor path is not normalized).
mojo_test(
    name = "fuzz_topk_sampling.mojo.test",
    size = "large",
    srcs = [
        "_fuzz.mojo",
        "fuzz_topk_sampling.mojo",
    ],
    exec_properties = {
        "test.resources:gpu-memory": "4",
    },
    main = "fuzz_topk_sampling.mojo",
    tags = [
        "gpu",
        "manual",
    ],
    target_compatible_with = ["//:has_gpu"],
    deps = [
        "//max:internal_utils",
        "//max:nn",
        "@mojo//:std",
    ],
)

# Target: EP MoE combine `send_tokens_back` write-offset containment.
